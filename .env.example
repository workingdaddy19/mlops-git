# ===========================================
# mlops 포탈 환경 설정 템플릿
# ===========================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
#   cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요! (.gitignore 처리됨)
#
# [설정 관리 방식]
#  - 비민감 설정(서비스 URL/리전/버킷/JUPYTER_ENVS 등)은 앱 코드 기본값
#    (app/core/config.py) + DB(system_settings, 관리자 Settings 화면)에서 관리합니다.
#    아래 "선택" 항목은 로컬에서 기본값을 바꾸고 싶을 때만 지정하면 됩니다.
#  - 운영(k8s)에서는 아래 [필수] 항목만 Secret(env)으로 주입합니다.

# ======== [필수] 부트스트랩 / 마스터 키 ========
# DB 접속정보 — DB에 담을 수 없어 반드시 env로 주입
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=mlops
DB_USER=mlops
DB_PASSWORD=__CHANGE_ME__
# 애플리케이션 마스터 키 (비밀번호 해시 pepper + JWT 서명) — 반드시 env. 구 이름 SECRET_KEY 도 호환.
APP_SECRET_KEY=__CHANGE_ME_RANDOM_SECRET__

# ======== [민감·선택] JupyterHub SSO ========
# 미설정 시 Jupyter SSO만 비활성(앱 기동에는 지장 없음)
JUPYTERHUB_JWT_SECRET=
JUPYTERHUB_ADMIN_TOKEN=

# ======== [선택] 앱 기타 ========
APP_PORT=6080
ACCESS_TOKEN_TTL_MINUTES=480

# ======== [선택] 로컬 개발용 서비스 URL 오버라이드 ========
# (미지정 시 config.py 기본값/ DB 설정값 사용)
# JUPYTER_BASE_URL=http://localhost:6888
# JUPYTER_TOKEN=
# MLFLOW_BASE_URL=http://localhost:6000
