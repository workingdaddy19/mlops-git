# ===========================================
# mlops 포탈 환경 설정 템플릿
# ===========================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
#   cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요! (.gitignore 처리됨)

# ---- Database ----
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=mlops
DB_USER=mlops
DB_PASSWORD=__CHANGE_ME__

# ---- Application ----
APP_PORT=6080
SECRET_KEY=__CHANGE_ME_RANDOM_SECRET__
ACCESS_TOKEN_TTL_MINUTES=480

# ---- Streamlit ----
STREAMLIT_PORT=6501

# ---- JupyterLab (Docker) ----
JUPYTER_BASE_URL=http://localhost:6888
JUPYTER_TOKEN=__CHANGE_ME__
# JupyterHub JWT SSO 시크릿 (필수 — 미설정 시 앱이 기동되지 않음)
JUPYTERHUB_JWT_SECRET=__CHANGE_ME__
# JupyterHub Admin API 토큰 (선택 — 토큰 발급 SSO 사용 시)
JUPYTERHUB_ADMIN_TOKEN=

# ---- MLflow (Docker) ----
MLFLOW_BASE_URL=http://localhost:6000

# ---- Airflow ----
AIRFLOW_BASE_URL=http://airflow.mlops.click
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=__CHANGE_ME__
